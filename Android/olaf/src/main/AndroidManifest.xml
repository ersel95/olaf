<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Android 13+ needs this for the capture notification. Requesting it at runtime is the
         host's call; without the grant Olaf simply stays quiet. The permission never reaches a
         production APK, because release builds link the no-op artifact. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application>

        <!-- The viewer lives in its own activity AND its own task: the host's back stack and
             navigation graph stay untouched, and on tablets or foldables Olaf can sit side by side
             with the app being debugged instead of replacing it. -->
        <activity
            android:name="com.olaf.ui.presentation.OlafViewerActivity"
            android:exported="false"
            android:label="Olaf"
            android:theme="@style/Theme.Olaf.Viewer"
            android:taskAffinity="com.olaf.viewer"
            android:launchMode="singleTask"
            android:resizeableActivity="true"
            android:excludeFromRecents="false"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode" />

        <!-- Serves only the export directory, and only for an explicit share action. The authority
             is derived from the host package, so several apps can ship Olaf side by side. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.olaf.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/olaf_file_paths" />
        </provider>

    </application>

</manifest>
